{
  "name": "apnapal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:fe": "npm run dev -w @apnapal/frontend",
    "dev:be": "npm run dev -w @apnapal/backend",
    "dev:worker": "npm run dev -w @apnapal/worker",
    "build:fe": "npm run build -w @apnapal/frontend",
    "typecheck:fe": "npm run typecheck -w @apnapal/frontend",
    "deploy:worker": "npm run deploy -w @apnapal/worker",
    "typecheck:worker": "npm run typecheck -w @apnapal/worker",
    "build:types": "npm run build -w @apnapal/types",
    "build:utils": "npm run build -w @apnapal/utils",
    "build:packages": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "pg": "^8.20.0",
    "supabase": "^2.89.1",
    "typescript": "^5.4.0"
  }
}
